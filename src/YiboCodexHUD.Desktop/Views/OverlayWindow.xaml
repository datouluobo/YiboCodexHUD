<Window x:Class="YiboCodexHUD.Desktop.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:YiboCodexHUD.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="YiboCodexHUD Overlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        WindowStartupLocation="Manual"
        d:DataContext="{d:DesignInstance Type=viewModels:OverlayViewModel}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <StackPanel Orientation="Horizontal">
            <TextBlock
                x:Name="DisplayTextBlock"
                Margin="0"
                FontFamily="{x:Static SystemFonts.MenuFontFamily}"
                FontSize="{Binding DisplayFontSize}"
                FontWeight="Normal"
                Foreground="{Binding DisplayForegroundBrush}"
                Opacity="{Binding DisplayOpacity}"
                IsHitTestVisible="False"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True"
                VerticalAlignment="Center"
                Text="{Binding DisplayText}"
                TextOptions.TextFormattingMode="Display"
                TextOptions.TextRenderingMode="Auto"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />

            <Border x:Name="InteractionDotHost"
                    Width="14"
                    Height="14"
                    Margin="5,0,0,0"
                    Background="Transparent"
                    MouseLeftButtonUp="OnInteractionDotMouseUp"
                    MouseRightButtonUp="OnInteractionDotMouseUp">
                <Border.ContextMenu>
                    <ContextMenu x:Name="InteractionMenu"
                                 StaysOpen="False"
                                 Opened="OnInteractionMenuOpened"
                                 Closed="OnInteractionMenuClosed">
                        <MenuItem Header="立即刷新"
                                  Command="{Binding RefreshNowCommand}" />
                        <MenuItem Header="打开设置"
                                  Click="OnOpenSettingsMenuItemClick" />
                        <Separator />
                        <MenuItem Header="退出"
                                  Click="OnExitMenuItemClick" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Ellipse Width="12"
                             Height="12"
                             Fill="#14000000"
                             Visibility="{Binding IsHudHovered, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Ellipse Width="15"
                             Height="15"
                             Fill="#16000000"
                             Visibility="{Binding IsInteractionDotActive, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="{x:Static SystemFonts.MenuFontFamily}"
                               FontSize="18"
                               Foreground="{Binding DisplayForegroundBrush}"
                               Opacity="{Binding DisplayOpacity}"
                               Text="·" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#4A000000"
                             Visibility="{Binding IsHudHovered, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Ellipse Width="6"
                             Height="6"
                             Fill="#7A000000"
                             Visibility="{Binding IsInteractionDotActive, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Window>
